# Rooted environment variables (copy to .env and fill real values; .env is gitignored).
# Never commit real secrets. Required external credentials are expected, not optional.

# --- Backblaze B2 (assets, manifests, Object-Lock checkpoints) ---
B2_KEY_ID=your_b2_key_id
B2_APP_KEY=your_b2_application_key
B2_BUCKET_DEV=rooted-dev            # no Object Lock retention, used for all iteration
B2_BUCKET_LOCKED=rooted-locked      # Object Lock compliance, final verified run / demo only
B2_REGION=us-west-004
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# --- Generation providers (Genblaze adapters) ---
GMI_CLOUD_API_KEY=your_gmi_cloud_key   # primary image model (Seedream / FLUX)
OPENAI_API_KEY=your_openai_key         # fallback image model
GENBLAZE_VERSION=0.3.2                  # pin the alpha SDK

# --- Database / queue ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rooted
REDIS_URL=redis://localhost:6379/0

# --- Signing (Ed25519 / C2PA) ---
ED25519_PRIVATE_KEY_PATH=./secrets/ed25519_private.pem   # gitignored
C2PA_CERT_CHAIN_PATH=./secrets/c2pa_chain.pem            # self-signed for dev

# --- Platform tokens (deploy) ---
VERCEL_TOKEN=your_vercel_token
RENDER_API_KEY=your_render_key
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret

# --- App ---
APP_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
