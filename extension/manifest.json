{
  "manifest_version": 3,
  "name": "Rooted - C2PA provenance recovery",
  "version": "0.1.0",
  "description": "Right-click any image to recover its stripped C2PA provenance via Rooted's Soft Binding Resolution API.",
  "permissions": ["contextMenus", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Rooted provenance recovery",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
