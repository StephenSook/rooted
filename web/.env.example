# Where next.config proxies /api/* to (the FastAPI SBR backend). The browser talks to /api
# same-origin, so there is no CORS. Defaults to the local dev API if unset.
API_PROXY_TARGET=http://localhost:8000

# Optional: point the typed client straight at a CORS-enabled backend instead of the /api proxy.
# Leave unset to use the same-origin proxy above.
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com
